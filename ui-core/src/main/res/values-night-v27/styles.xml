<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark mode overrides for API 27+ -->
    <style name="AirwallexDefaultTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorAccent">@color/airwallex_tint_color</item>
        <item name="colorPrimary">@color/airwallex_tint_color</item>
        <item name="colorPrimaryDark">@color/airwallex_color_grey_100</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:actionMenuTextColor">@color/airwallex_menu_text</item>
        <item name="android:homeAsUpIndicator">@drawable/airwallex_ic_close</item>
        <item name="android:windowBackground">@color/airwallex_window_background</item>
        <item name="android:navigationBarColor">@color/airwallex_navigation_bar</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:statusBarColor">@color/airwallex_status_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorControlActivated">@color/airwallex_tint_color</item>
    </style>
</resources>
